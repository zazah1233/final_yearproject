SECRET_KEY=change-this-in-production
DATABASE_URL=sqlite:///zazah.db

# Diagnosis thresholds (0-1 range)
THRESHOLD_HIGH=0.85
THRESHOLD_LOW=0.10
RF_THRESHOLD=0.50

# Optional: bootstrap admin account created on first app start
ADMIN_USERNAME=admin
ADMIN_PASSWORD=StrongPassword123

# Optional: ML model retraining token
ML_MODEL_RETRAIN_TOKEN=

# Optional cookie hardening for production HTTPS
SESSION_COOKIE_SECURE=false
REMEMBER_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_SAMESITE=Lax

# Optional logging
LOG_LEVEL=INFO
LOG_FILE=zazah.log